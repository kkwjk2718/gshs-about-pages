---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  current?: "about" | "docs" | "status" | "updates";
}

const {
  title,
  description = "GSHS.app 소개와 공식 안내를 담은 공개 사이트",
  current = "about",
} = Astro.props;

const navLinks = [
  { key: "about", label: "About", href: "https://about.gshs.app" },
  { key: "docs", label: "Docs", href: "https://docs.gshs.app" },
  { key: "status", label: "Status", href: "https://status.gshs.app" },
  { key: "updates", label: "Updates", href: "https://updates.gshs.app" },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/school-mark.png" />
  </head>
  <body>
    <header class="site-shell">
      <div class="topbar">
        <a class="brand" href="https://gshs.app">
          <img src="/school-mark.png" alt="경남과학고등학교 로고" />
          <div>
            <strong>GSHS.app</strong>
            <span>공식 보조 사이트</span>
          </div>
        </a>

        <nav class="nav" aria-label="보조 사이트 탐색">
          {
            navLinks.map((link) => (
              <a
                href={link.href}
                class:list={["nav-link", current === link.key && "is-current"]}
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>

    <main class="site-shell">
      <slot />
    </main>

    <footer class="site-shell footer">
      <p>경남과학고등학교 정보부 · IEUM</p>
      <p>
        본 서비스: <a href="https://gshs.app">gshs.app</a>
      </p>
    </footer>
  </body>
</html>
